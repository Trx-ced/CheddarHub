local bindingKey = false

local function clamp(n, a, b)
	if n < a then return a end
	if n > b then return b end
	return n
end

local function keyName(kc)
	local s = tostring(kc)
	return s:match("^Enum%.KeyCode%.(.+)$") or s
end

local function planar(v)
	return Vector3.new(v.X, 0, v.Z)
end

local function safeUnit(v)
	local m = v.Magnitude
	if m <= 1e-6 then return Vector3.zero end
	return v / m
end

local function resolveTarget()
	local char = player.Character
	if char and char.Parent then
		local hrp = char:FindFirstChild("HumanoidRootPart")
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hrp and hum then
			return char, hum, hrp, "player.Character"
		end
	end

	local live = Workspace:FindFirstChild("Live")
	if live then
		local m = live:FindFirstChild(player.Name)
		if m and m:IsA("Model") then
			local hum = m:FindFirstChildOfClass("Humanoid")
			local hrp = m:FindFirstChild("HumanoidRootPart")
			if hum and hrp then
				return m, hum, hrp, "workspace.Live." .. player.Name
			end
		end

		local m2 = live:FindFirstChild("heartuchihaleader")
		if m2 and m2:IsA("Model") then
			local hum = m2:FindFirstChildOfClass("Humanoid")
			local hrp = m2:FindFirstChild("HumanoidRootPart")
			if hum and hrp then
				return m2, hum, hrp, "workspace.Live.heartuchihaleader"
			end
		end
	end

	return nil
end

local function findBodyVelocity(rootPart, model)
	if rootPart then
		local bv = rootPart:FindFirstChildOfClass("BodyVelocity")
		if bv then return bv end
		for _, ch in ipairs(rootPart:GetChildren()) do
			if ch:IsA("BodyVelocity") then
				return ch
			end
		end
	end
	if model then
		for _, d in ipairs(model:GetDescendants()) do
			if d:IsA("BodyVelocity") then
				return d
			end
		end
	end
	return nil
end

local function rayParamsExclude(character)
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = { character }
	params.IgnoreWater = true
	return params
end

local function raycastDown(character, origin, dist)
	return Workspace:Raycast(origin, Vector3.new(0, -(dist or 350), 0), rayParamsExclude(character))
end

local function raycastForward(character, origin, dir, dist)
	return Workspace:Raycast(origin, dir * (dist or 6), rayParamsExclude(character))
end

