	local bb = Instance.new("BillboardGui")
	bb.Name = "TitanESP_Info"
	bb.Adornee = nape
	bb.AlwaysOnTop = true
	bb.Size = UDim2.fromOffset(240, 36)
	bb.StudsOffset = Vector3.new(0, 3.1, 0)

