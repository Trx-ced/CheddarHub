local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local remote = ReplicatedStorage:WaitForChild("ODM_VelocityBoostRemote")

local State = {
	Enabled = false,
	Mult = 1.10,
	Add = 0,
	Max = 400,
	HoldKey = Enum.KeyCode.H,
	Holding = false,
}

local function clamp(n, a, b)
	if n < a then return a end
	if n > b then return b end
	return n
end

local function keyName(kc)
	return tostring(kc):gsub("Enum.KeyCode%.", "")
end

local function parseKey(text, fallback)
	local s = (text or ""):upper():gsub("%s+", "")
	if s == "" then return fallback end
	local ok, v = pcall(function() return Enum.KeyCode[s] end)
	if ok and v then return v end
	return fallback
end

local function parseNum(text, fallback)
	local n = tonumber((text or ""):match("[%d%.%-]+"))
	return n or fallback
end

local function push()
	remote:FireServer({
		cmd = "set",
		enabled = State.Enabled,
		holding = State.Holding,
		mult = State.Mult,
		add = State.Add,
		max = State.Max,
		maxHard = 400,
	})
end

local function mk(className, props)
	local inst = Instance.new(className)
	for k, v in pairs(props) do inst[k] = v end
	return inst
end

local gui = mk("ScreenGui", { Name="ODM_VelocityBoostUI", ResetOnSpawn=false, Parent=playerGui })

local frame = mk("Frame", {
	Parent = gui,
	Position = UDim2.new(0, 20, 0.5, -110),
	Size = UDim2.new(0, 330, 0, 220),
	BackgroundTransparency = 0.15,
	BorderSizePixel = 0
})
mk("UICorner", { Parent = frame, CornerRadius = UDim.new(0, 12) })

local title = mk("TextLabel", {
	Parent = frame,
	BackgroundTransparency = 1,
	Position = UDim2.new(0, 10, 0, 8),
	Size = UDim2.new(1, -20, 0, 24),
	Font = Enum.Font.GothamBold,
	TextSize = 14,
	TextXAlignment = Enum.TextXAlignment.Left,
	Text = "Velocity Modifier (Server Applied)"
})

local status = mk("TextLabel", {
	Parent = frame,
	BackgroundTransparency = 1,
	Position = UDim2.new(0, 10, 0, 34),
	Size = UDim2.new(1, -20, 0, 18),
	Font = Enum.Font.Gotham,
	TextSize = 12,
	TextXAlignment = Enum.TextXAlignment.Left,
	Text = ""
})

local function row(y, labelText, defaultText)
	mk("TextLabel", {
		Parent = frame,
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 10, 0, y),
		Size = UDim2.new(0, 190, 0, 20),
		Font = Enum.Font.Gotham,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		Text = labelText
	})

	local box = mk("TextBox", {
		Parent = frame,
		Position = UDim2.new(0, 210, 0, y),
		Size = UDim2.new(0, 100, 0, 20),
		Text = defaultText,
		ClearTextOnFocus = false,
		Font = Enum.Font.Gotham,
		TextSize = 12
	})
	mk("UICorner", { Parent = box, CornerRadius = UDim.new(0, 8) })
	return box
end

local multBox = row(62, "VelocityMultiplier (cur*mult)", tostring(State.Mult))
local addBox  = row(88, "AddSpeed (+)", tostring(State.Add))
local maxBox  = row(114, "MaxSpeed (cap, <=400)", tostring(State.Max))
local keyBox  = row(140, "Hold Key (H/Y/F etc)", keyName(State.HoldKey))

local toggle = mk("TextButton", {
	Parent = frame,
	Position = UDim2.new(0, 10, 0, 170),
	Size = UDim2.new(1, -20, 0, 36),
	Font = Enum.Font.GothamBold,
	TextSize = 14,
	Text = "Toggle: OFF",
	AutoButtonColor = true
})
mk("UICorner", { Parent = toggle, CornerRadius = UDim.new(0, 10) })

local function refresh()
	status.Text = ("Enabled: %s | Hold: %s | Key: %s")
		:format(State.Enabled and "ON" or "OFF", State.Holding and "DOWN" or "UP", keyName(State.HoldKey))
	toggle.Text = State.Enabled and "Toggle: ON" or "Toggle: OFF"
end

local function applyFromUI()
	State.Mult = clamp(parseNum(multBox.Text, State.Mult), 0, 5)
	State.Add  = clamp(parseNum(addBox.Text, State.Add), -400, 400)
	State.Max  = clamp(parseNum(maxBox.Text, State.Max), 0, 400)
	State.HoldKey = parseKey(keyBox.Text, State.HoldKey)

	multBox.Text = tostring(State.Mult)
	addBox.Text = tostring(State.Add)
	maxBox.Text = tostring(State.Max)
	keyBox.Text = keyName(State.HoldKey)

	refresh()
	push()
end

toggle.MouseButton1Click:Connect(function()
	State.Enabled = not State.Enabled
	applyFromUI()
end)

multBox.FocusLost:Connect(applyFromUI)
addBox.FocusLost:Connect(applyFromUI)
maxBox.FocusLost:Connect(applyFromUI)
keyBox.FocusLost:Connect(applyFromUI)

UIS.InputBegan:Connect(function(input, gp)
	if gp then return end
	if UIS:GetFocusedTextBox() then return end

	State.HoldKey = parseKey(keyBox.Text, State.HoldKey)

	if input.KeyCode == State.HoldKey and State.Enabled then
		State.Holding = true
		refresh()
		push()
	end
end)

UIS.InputEnded:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == State.HoldKey and State.Enabled then
		State.Holding = false
		refresh()
		push()
	end
end)

refresh()
applyFromUI()
