local lastBV, lastBVDebug
local origMaxForce, origP
local touchedBV = false

local function restoreBV()
	if lastBV and lastBV.Parent and touchedBV then
		if origMaxForce then pcall(function() lastBV.MaxForce = origMaxForce end) end
		if origP ~= nil then pcall(function() lastBV.P = origP end) end
	end
	lastBV, lastBVDebug = nil, nil
	origMaxForce, origP = nil, nil
	touchedBV = false
end

local function floorSnap(model, root)
	local hit = raycastDown(model, root.Position, 500)
	if not hit then return nil end

	local groundY = hit.Position.Y
	local dist = root.Position.Y - groundY

	-- If we're close to ground and "sinking", snap up a bit to prevent falling through grass/terrain
	if dist <= (State.FloorSnapHeight + State.FloorSinkTolerance) then
		local minY = groundY + State.FloorSnapHeight
		if root.Position.Y < minY then
			local pos = root.Position
			local cf = root.CFrame
			local rot = cf - cf.Position
			root.CFrame = CFrame.new(pos.X, minY, pos.Z) * rot
		end
	end

	return hit, dist
end

local function wallSlide(model, root, desiredPlanarVel)
	local h = desiredPlanarVel.Magnitude
	if h <= 1e-3 then return desiredPlanarVel end

	local dir = desiredPlanarVel / h
	local origin = root.Position
	local hit = raycastForward(model, origin, dir, State.WallCheckDist)

	if not hit or not hit.Instance then
		return desiredPlanarVel
	end

	-- Only treat it like a blocking wall if it's actually collidable
	if hit.Instance.CanCollide == false then
		return desiredPlanarVel
	end

	local n = hit.Normal
	-- remove component going into the wall normal so we slide instead of "pushing through"
	local into = desiredPlanarVel:Dot(n)
	if into < 0 then
		local slid = desiredPlanarVel - (n * into)
		return slid * State.WallSlideLoss
	end

	return desiredPlanarVel
end

local function applyOnce()
	State.Mult = clamp(tonumber(multBox.Text) or State.Mult, 0, 5)
	State.Add  = clamp(tonumber(addBox.Text) or State.Add, -400, 400)
	State.Max  = clamp(tonumber(maxBox.Text) or State.Max, 0, 4000)

	if not State.Enabled then
		status.Text = "Status: disabled"
		restoreBV()
		return
	end

	if UIS:GetFocusedTextBox() then
		status.Text = "Status: chatting"
		restoreBV()
		return
	end

	local hookHeld = UIS:IsKeyDown(Enum.KeyCode.E) or UIS:IsKeyDown(Enum.KeyCode.Q)
	if not hookHeld then
		status.Text = "Status: enabled (hook with E/Q)"
		restoreBV()
		return
	end

	local model, humanoid, root, which = resolveTarget()
	if not model then
		status.Text = "Status: no target model"
		restoreBV()
		return
	end
	targetLbl.Text = "Target: " .. which

	local bv = findBodyVelocity(root, model)
	if not bv then
		status.Text = "Status: no BodyVelocity found (hook first)"
		restoreBV()
		return
	end

	local id = bv:GetDebugId()
	if bv ~= lastBV or id ~= lastBVDebug then
		restoreBV()
		lastBV = bv
		lastBVDebug = id
		origMaxForce = bv.MaxForce
		origP = bv.P
		touchedBV = false
	end

	if bv.MaxForce ~= State.Force then
		bv.MaxForce = State.Force
		touchedBV = true
	end
	if bv.P ~= State.P then
		bv.P = State.P
		touchedBV = true
	end

	-- floor protection first (prevents under-terrain)
	local hitDown, distToFloor = floorSnap(model, root)

	local v0 = bv.Velocity
	local h0 = planar(v0)
	local spd = h0.Magnitude

	local dir = safeUnit(h0)
	if dir.Magnitude <= 1e-6 then
		dir = safeUnit(planar(root.CFrame.LookVector))
	end
	if dir.Magnitude <= 1e-6 then
		status.Text = "Status: BV has no planar direction"
		return
	end

	local targetSpeed = clamp(spd * State.Mult + State.Add, 0, State.Max)
	local desiredH = dir * targetSpeed

	-- wall/solid protection (prevents phasing/jitter into cliffs/walls)
	desiredH = wallSlide(model, root, desiredH)

	-- Y handling: keep real Y if it's higher, but don't slam downward near ground
	local y = v0.Y
	local realY = root.AssemblyLinearVelocity.Y
	if realY > y then y = realY end

	if hitDown and distToFloor then
		if distToFloor <= State.NearGroundDist then
			-- near ground: reduce downward forcing so we don't get pushed under terrain
			if y < State.MaxDownY then
				y = State.MaxDownY
			end
			-- extra: if extremely close, don't go down at all
			if distToFloor <= (State.FloorSnapHeight + 0.25) and y < -5 then
				y = -5
			end
		end
	end

	bv.Velocity = Vector3.new(desiredH.X, y, desiredH.Z)
	status.Text = ("Status: %s | %.1f -> %.1f"):format(bv.Name, spd, targetSpeed)
end

RunService.PreSimulation:Connect(function()
	applyOnce()
end)
