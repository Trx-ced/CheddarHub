	box.LineThickness = 0.05
	box.Color3 = Color3.fromRGB(255, 0, 0)
	local t = math.clamp(State.TitanESPBoxTransparency, 0, 1)
	box.Transparency = t
	box.SurfaceTransparency = t
	box.Parent = nape
	return box
end

