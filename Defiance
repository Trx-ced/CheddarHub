end))

task.spawn(function()
	while not unloaded do
		if State.DisableGrabHitboxes then
			for _, d in ipairs(TitansFolder:GetDescendants()) do
				if d:IsA("BasePart") and isAntiGrabTarget(d) then
					d.CanCollide = false
					d.CanTouch = false
					d.CanQuery = false
				end
			end

			local live = workspace:FindFirstChild("Live")
			if live then
				local plr = live:FindFirstChild(player.Name)
				if plr then
					local hrp = plr:FindFirstChild("HumanoidRootPart")
					if hrp then
						hrp.CanTouch = false
					end
				end
			end

			local char = player.Character
			if char then
				for _, d in ipairs(char:GetDescendants()) do
					if d:IsA("BasePart") then
						d.CanCollide = false
						d.CanTouch = false
						d.CanQuery = false
					end
				end
			end
		end

		if State.PlayerNoTouch then
			applyPlayerNoTouch()
		end

		task.wait(0.2)
	end
end)

local function getRoot()
	local char = player.Character
	if not char then return nil end
	return char:FindFirstChild("HumanoidRootPart")
end

local function getTitanType(rig)
	local attr = rig:GetAttribute("TitanType")
	if typeof(attr) == "string" and attr ~= "" then
		return attr
	end
	return rig.Name
end

local debugByNape = {}

local function makeTitanBox(nape)
