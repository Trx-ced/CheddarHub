local VeloMultiplierV6 = {}
do
	local UIS = UserInputService

	local lastBV = nil
	local lastBVDebug = nil
	local origMaxForce = nil
	local origP = nil
	local touchedBV = false

	local function clamp(n, a, b)
		if n < a then return a end
		if n > b then return b end
		return n
	end

	local function planar(v)
		return Vector3.new(v.X, 0, v.Z)
	end

	local function safeUnit(v)
		local m = v.Magnitude
		if m <= 1e-6 then return Vector3.zero end
		return v / m
	end

	local function resolveTarget()
		local char = player.Character
		if char and char.Parent then
			local hrp = char:FindFirstChild("HumanoidRootPart")
			local hum = char:FindFirstChildOfClass("Humanoid")
			if hrp and hum then
				return char, hum, hrp, "player.Character"
			end
		end

		local live = Workspace:FindFirstChild("Live")
		if live then
			local m = live:FindFirstChild(player.Name)
			if m and m:IsA("Model") then
				local hum = m:FindFirstChildOfClass("Humanoid")
				local hrp = m:FindFirstChild("HumanoidRootPart")
				if hum and hrp then
					return m, hum, hrp, "workspace.Live." .. player.Name
				end
			end

			local m2 = live:FindFirstChild("heartuchihaleader")
			if m2 and m2:IsA("Model") then
				local hum = m2:FindFirstChildOfClass("Humanoid")
				local hrp = m2:FindFirstChild("HumanoidRootPart")
				if hum and hrp then
					return m2, hum, hrp, "workspace.Live.heartuchihaleader"
				end
			end
		end

		return nil
	end

	local function findBodyVelocity(rootPart, model)
		if rootPart then
			local bv = rootPart:FindFirstChildOfClass("BodyVelocity")
			if bv then return bv end
			for _, ch in ipairs(rootPart:GetChildren()) do
				if ch:IsA("BodyVelocity") then
					return ch
				end
			end
		end
		if model then
			for _, d in ipairs(model:GetDescendants()) do
				if d:IsA("BodyVelocity") then
					return d
				end
			end
		end
		return nil
	end

	local function rayParamsExclude(character)
		local params = RaycastParams.new()
		params.FilterType = Enum.RaycastFilterType.Exclude
		params.FilterDescendantsInstances = { character }
		params.IgnoreWater = true
		return params
	end

	local function raycastDown(character, origin, dist)
		return Workspace:Raycast(origin, Vector3.new(0, -(dist or 350), 0), rayParamsExclude(character))
	end

	local function raycastForward(character, origin, dir, dist)
		return Workspace:Raycast(origin, dir * (dist or 6), rayParamsExclude(character))
	end

	local function restoreBV()
		if lastBV and lastBV.Parent and touchedBV then
			if origMaxForce then pcall(function() lastBV.MaxForce = origMaxForce end) end
			if origP ~= nil then pcall(function() lastBV.P = origP end) end
		end
		lastBV, lastBVDebug = nil, nil
		origMaxForce, origP = nil, nil
		touchedBV = false
	end

	local function floorSnap(model, root)
		local hit = raycastDown(model, root.Position, 500)
		if not hit then return nil end

		local groundY = hit.Position.Y
		local dist = root.Position.Y - groundY

		if dist <= (State.V6FloorSnapHeight + State.V6FloorSinkTolerance) then
			local minY = groundY + State.V6FloorSnapHeight
			if root.Position.Y < minY then
				local pos = root.Position
				local cf = root.CFrame
				local rot = cf - cf.Position
				root.CFrame = CFrame.new(pos.X, minY, pos.Z) * rot
			end
		end

		return hit, dist
	end

	local function wallSlide(model, root, desiredPlanarVel)
		local h = desiredPlanarVel.Magnitude
		if h <= 1e-3 then return desiredPlanarVel end

		local dir = desiredPlanarVel / h
		local origin = root.Position
		local hit = raycastForward(model, origin, dir, State.V6WallCheckDist)

		if not hit or not hit.Instance then
			return desiredPlanarVel
		end

		if hit.Instance.CanCollide == false then
			return desiredPlanarVel
		end

		local n = hit.Normal
		local into = desiredPlanarVel:Dot(n)
		if into < 0 then
			local slid = desiredPlanarVel - (n * into)
			return slid * State.V6WallSlideLoss
		end

		return desiredPlanarVel
	end

	local function applyOnce()
		State.V6Mult = clamp(State.V6Mult, 0, 5)
		State.V6Add  = clamp(State.V6Add, -400, 400)
		State.V6Max  = clamp(State.V6Max, 0, 4000)

		if not State.V6Enabled then
			restoreBV()
			return
		end

		if UIS:GetFocusedTextBox() then
			restoreBV()
			return
		end

		local hookHeld = UIS:IsKeyDown(Enum.KeyCode.E) or UIS:IsKeyDown(Enum.KeyCode.Q)
		if not hookHeld then
			restoreBV()
			return
		end

		local model, humanoid, root = resolveTarget()
		if not model then
			restoreBV()
			return
		end

		local bv = findBodyVelocity(root, model)
		if not bv then
			restoreBV()
			return
		end

		local id = bv:GetDebugId()
		if bv ~= lastBV or id ~= lastBVDebug then
			restoreBV()
			lastBV = bv
			lastBVDebug = id
			origMaxForce = bv.MaxForce
			origP = bv.P
			touchedBV = false
		end

		if bv.MaxForce ~= State.V6Force then
			bv.MaxForce = State.V6Force
			touchedBV = true
		end
		if bv.P ~= State.V6P then
			bv.P = State.V6P
			touchedBV = true
		end

		local hitDown, distToFloor = floorSnap(model, root)

		local v0 = bv.Velocity
		local h0 = planar(v0)
		local spd = h0.Magnitude

		local dir = safeUnit(h0)
		if dir.Magnitude <= 1e-6 then
			dir = safeUnit(planar(root.CFrame.LookVector))
		end
		if dir.Magnitude <= 1e-6 then
			return
		end

		local targetSpeed = clamp(spd * State.V6Mult + State.V6Add, 0, State.V6Max)
		local desiredH = dir * targetSpeed

		desiredH = wallSlide(model, root, desiredH)

		local y = v0.Y
		local realY = root.AssemblyLinearVelocity.Y
		if realY > y then y = realY end

		if hitDown and distToFloor then
			if distToFloor <= State.V6NearGroundDist then
				if y < State.V6MaxDownY then
					y = State.V6MaxDownY
				end
				if distToFloor <= (State.V6FloorSnapHeight + 0.25) and y < -5 then
					y = -5
				end
			end
		end

		bv.Velocity = Vector3.new(desiredH.X, y, desiredH.Z)
	end

	local stepEvent = RunService.PreSimulation or RunService.Heartbeat
	track(stepEvent:Connect(function()
		applyOnce()
	end))

	function VeloMultiplierV6.Stop()
		restoreBV()
	end
end

